ITOP_URL=https://your-itop.example.com
ITOP_VERSION=1.3
ITOP_VERIFY_SSL=true
ITOP_TIMEOUT=30

# Optional: bind address/port for the MCP server (streamable-http transport).
# MCP_HOST=0.0.0.0
# MCP_PORT=8096

# Public base URL of this MCP server.
# REQUIRED when running behind a reverse proxy or with a public hostname.
# The hostname is extracted from this URL and added to the MCP SDK's
# DNS rebinding protection allowlist (TransportSecuritySettings).
# Without it, requests whose Host header contains the public hostname
# will be rejected with 421 Misdirected Request.
MCP_SERVER_URL=https://mcp.your-domain.com

# SQLite database path for the attachment image store.
# Defaults to /app/data/attachment_store.db (Docker) or next to the module
# when running locally. Must be a path writable by the process user.
# When using docker-compose the /app/data directory is owned by the mcp user
# and is backed by a named volume so the DB persists across restarts.
# IMAGE_STORE_DB=/app/data/attachment_store.db

# TTL in seconds for image entries in the attachment store (default: 3600 = 1 h).
# IMAGE_STORE_TTL=3600

# NOTE: iTop authentication is no longer configured here.
# Each MCP client must present its own iTop API token as a bearer token
# in the "Authorization: Bearer <itop_token>" header when connecting.
# The server rejects connections without a non-empty bearer token at
# the MCP handshake (initialize) and forwards that token to iTop as
# auth_token on every REST/JSON API call.

# Set to true to enable verbose debug logging of client<->mcp<->iTop
# request/response payloads (auth secrets are always redacted).
MCP_DEBUG=false
