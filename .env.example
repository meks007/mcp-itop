ITOP_URL=https://your-itop.example.com
ITOP_VERSION=1.3
ITOP_VERIFY_SSL=true
ITOP_TIMEOUT=30

# Optional: bind address/port for the MCP server (streamable-http transport).
# MCP_HOST=0.0.0.0
# MCP_PORT=8096

# Public base URL of this MCP server.
# REQUIRED when running behind a reverse proxy or with a public hostname.
# The hostname is extracted from this URL and added to the MCP SDK's
# DNS rebinding protection allowlist (TransportSecuritySettings).
# Without it, requests whose Host header contains the public hostname
# will be rejected with 421 Misdirected Request.
MCP_SERVER_URL=https://mcp.your-domain.com

# SQLite database path for the attachment image store.
# Defaults to /app/data/attachment_store.db (Docker) or next to the module
# when running locally. Must be a path writable by the process user.
# When using docker-compose the /app/data directory is owned by the mcp user
# and is backed by a named volume so the DB persists across restarts.
# IMAGE_STORE_DB=/app/data/attachment_store.db

# TTL in seconds for image entries in the attachment store (default: 3600 = 1 h).
# IMAGE_STORE_TTL=3600

# Interval in seconds between background incremental_vacuum runs on the
# attachment store DB (default: 3600 = 1 h). Set to 0 to disable.
# IMAGE_STORE_VACUUM_INTERVAL=3600

# Maximum image size in bytes. Images exceeding this limit are first compressed
# via JPEG quality reduction, then downscaled if still too large.
# Default: 1048576 (1 MB). Set to 0 to disable size capping entirely.
# IMAGE_MAX_BYTES=1048576

# Starting JPEG quality for image normalization (1-95).
# If the encoded size exceeds IMAGE_MAX_BYTES the quality is reduced in steps
# (75, 60, 45, 30) before falling back to downscaling. Default: 85.
# IMAGE_JPEG_QUALITY=85

# TTL in seconds for the resolve_key lookup cache (default: 86400 = 24 h).
# Entries older than this are evicted on the next resolve_key call.
# Set to 0 to disable caching entirely.
# RESOLVE_KEY_CACHE_TTL=86400

# Interval in seconds between background cleanup cycles.
# All periodic activities (resolve_key cache eviction, expired image rows,
# expired inline image ref rows) share this single interval.
# Default: 300 s (5 min).
# CLEANUP_INTERVAL=300

# TTL in seconds for inline image ref entries written to SQLite by
# format_and_cache(). Entries older than this are treated as a cache miss
# and refreshed on the next itop_get_ticket_images call.
# Default: 3600 s (1 h).
# INLINE_IMAGE_REF_TTL=3600

# NOTE: iTop authentication is no longer configured here.
# Each MCP client must present its own iTop API token as a bearer token
# in the "Authorization: Bearer <itop_token>" header when connecting.
# The server rejects connections without a non-empty bearer token at
# the MCP handshake (initialize) and forwards that token to iTop as
# auth_token on every REST/JSON API call.

# Set to true to enable verbose debug logging of client<->mcp<->iTop
# request/response payloads (auth secrets are always redacted).
MCP_DEBUG=false

# Set to true to additionally log HTTP request and response headers for
# every iTop REST/JSON API call. Only takes effect when MCP_DEBUG=true.
# Auth secrets in headers (e.g. Authorization) are always redacted.
# MCP_DEBUG_HEADERS=false
